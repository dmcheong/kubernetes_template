# Configuration globale pour les scripts kubernetes_template
# Ce fichier est chargé par tous les scripts via global_configuration_file
# definition de la structure des répertoires de travail

libs_root="${root_path}/lib"

# Répertoires standards
LOGS_DIR=logs
TESTS_DIR=tests
SCRIPTS_DIR=scripts
RESOURCES_DIR=resources

# Debug et logging
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# Versions minimales des outils
# ============================================================
ASDF_MIN_VERSION="0.18.0"
ASDF_TARGET_VERSION="0.18.0"

MIN_DOCKER_VERSION="24.0.0"

HELM_MIN_VERSION="3.14.0"

KUBECTL_VERSION="1.35.0"

KUBESCORE_MIN_VERSION="1.20.0"
KUBESCORE_TARGET_VERSION="1.20.0"

MINIKUBE_MIN_VERSION="1.37.0"

# ============================================================
# Configuration Sealed Secrets
# ============================================================
SEALEDSECRETS_REPO="bitnami-labs/sealed-secrets"

# ============================================================
# Configuration NFS (kubeseal / PV)
# ============================================================
NFS_SHARE_DIR="/data"
NFS_EXPORT_DIR="/etc/exports.d"
NFS_EXPORT_FILE="${NFS_EXPORT_DIR}/k8s-nfs.exports"

# ============================================================
# Chemins utilisateur locaux
# ============================================================
LOCAL_BIN="${HOME}/.local/bin"

# ============================================================
# Configuration Kubernetes / Namespaces
# ============================================================
DEMO_NAMESPACE="demo"
MONITORING_NAMESPACE="monitoring"
KONG_NAMESPACE="kong"
TRAEFIK_NAMESPACE="traefik"
HASHICORP_NAMESPACE="hashicorp"
AWS_NAMESPACE="awsecret"

# ============================================================
# Configuration Prometheus / Grafana
# ============================================================
PROMETHEUS_REPO_NAME="prometheus-community"
PROMETHEUS_REPO_URL="https://prometheus-community.github.io/helm-charts"
PROMETHEUS_RELEASE="kube-prometheus-stack"
PROMETHEUS_CHART="${PROMETHEUS_REPO_NAME}/kube-prometheus-stack"

# ============================================================
# Configuration OpenTelemetry
# ============================================================
OTEL_REPO_NAME="open-telemetry"
OTEL_REPO_URL="https://open-telemetry.github.io/opentelemetry-helm-charts"
OTEL_RELEASE="opentelemetry-collector"
OTEL_CHART="${OTEL_REPO_NAME}/opentelemetry-collector"

# ============================================================
# Configuration Kong Gateway + Bitnami
# ============================================================
KONG_REPO_NAME="kong"
KONG_REPO_URL="https://charts.konghq.com"
KONG_RELEASE="kong"
KONG_CHART="${KONG_REPO_NAME}/ingress"

BITNAMI_RELEASE="bitnami"
BITNAMI_REPO_URL="https://charts.bitnami.com/bitnami"

# ============================================================
# Configuration traefik
# ============================================================
TRAEFIK_REPO_NAME="traefik"
TRAEFIK_REPO_URL="https://traefik.github.io/charts"
TRAEFIK_RELEASE="traefik"
TRAEFIK_CHART="${TRAEFIK_REPO_NAME}/traefik"

# ============================================================
# Configuration hashicorp
# ============================================================
HASH_REPO_NAME="hashicorp"
HASH_REPO_URL="https://helm.releases.hashicorp.com"
HASH_RELEASE="vault"
HASH_CHART="${HASH_REPO_NAME}/vault"
